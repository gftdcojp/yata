# Lightweight test image for yata-server (local dev, not production)
FROM rust:1.93-slim-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY Cargo.toml Cargo.lock ./

# Copy all crate manifests for dependency resolution
COPY yata-core/Cargo.toml       yata-core/Cargo.toml
COPY yata-arrow/Cargo.toml      yata-arrow/Cargo.toml
COPY yata-object/Cargo.toml     yata-object/Cargo.toml
COPY yata-s3/Cargo.toml         yata-s3/Cargo.toml
COPY yata-server/Cargo.toml     yata-server/Cargo.toml
COPY yata-bench/Cargo.toml      yata-bench/Cargo.toml
COPY yata-store/Cargo.toml      yata-store/Cargo.toml
COPY yata-cypher/Cargo.toml     yata-cypher/Cargo.toml
COPY yata-grin/Cargo.toml       yata-grin/Cargo.toml
COPY yata-graph/Cargo.toml      yata-graph/Cargo.toml
COPY yata-engine/Cargo.toml     yata-engine/Cargo.toml
COPY yata-gie/Cargo.toml        yata-gie/Cargo.toml
COPY yata-vex/Cargo.toml        yata-vex/Cargo.toml
# Stub src for dep caching
RUN for d in yata-core yata-arrow yata-object yata-s3 \
             yata-store yata-cypher yata-grin yata-graph yata-engine \
             yata-gie yata-vex; do \
      mkdir -p $d/src && echo '' > $d/src/lib.rs; \
    done && \
    mkdir -p yata-server/src && \
    echo 'fn main(){}' > yata-server/src/main.rs && \
    echo '' > yata-server/src/lib.rs && \
    mkdir -p yata-bench/src && \
    echo 'fn main(){}' > yata-bench/src/main.rs

RUN cargo build --release -p yata-server 2>&1 | tail -5 || true

# Full source
COPY . .
RUN find . -name 'lib.rs' -o -name 'main.rs' | xargs touch
RUN cargo build --release -p yata-server

# Runtime
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/ai-gftd-yata-server /usr/local/bin/ai-gftd-yata-server

RUN mkdir -p /data/yata
EXPOSE 8081 9090
ENTRYPOINT ["/usr/local/bin/ai-gftd-yata-server"]
